{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "../../../",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@packages/*": ["./packages/*"]
    }
  },
  "include": [
    "src/**/*",
    "../../packages/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}